# Configuration Settings
# Modify these variables to customize your demo setup

DEMO_NAME=zenflow
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

LANGUAGE=en
CURRENCY=usd

PRIMARY_COLOR="#221B35"
SECONDARY_COLOR="#F26552"

CUSTOM_LOGO=
CUSTOM_HERO=

CHECKOUT_METHOD=elements-checkout
