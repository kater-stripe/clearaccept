NEXT_PUBLIC_CUSTOM_HERO=$CUSTOM_HERO
NEXT_PUBLIC_CHECKOUT_METHOD=$CHECKOUT_METHOD
NEXT_PUBLIC_CHARGE_TYPE=$CHARGE_TYPE
NEXT_PUBLIC_ONBOARDING_TYPE=$ONBOARDING_TYPE