ONBOARDING_TYPE=embedded

# Client side accessible Variables
# Warning: Modify these only if you understand the implications

NEXT_PUBLIC_DEMO_NAME=$DEMO_NAME
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=$STRIPE_PUBLISHABLE_KEY
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY_FOR_MEMBERSHIPS=$STRIPE_PUBLISHABLE_KEY_FOR_MEMBERSHIPS
NEXT_PUBLIC_LANGUAGE=$LANGUAGE
NEXT_PUBLIC_CURRENCY=$CURRENCY
NEXT_PUBLIC_PRIMARY_COLOR=$PRIMARY_COLOR
NEXT_PUBLIC_SECONDARY_COLOR=$SECONDARY_COLOR
